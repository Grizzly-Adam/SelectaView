<?xml version="1.0" encoding="UTF-8"?>

<component name="MainScene" extends="Scene" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://rokudev.roku.com/rokudev/schema/RokuSceneGraph.xsd" initialFocus="playlistList">
<script type="text/brightscript" uri="pkg:/components/MainScene/MainScene.brs"/>
<children>
    <Rectangle
        id="sidePanel"
        translation="[0, 0]"
        width="460"
        height="1080"
        color="0x8fcdc1DD"
        visible="true">
        
        <Poster
            id="logoImage"
            uri="pkg:/images/selectaview.png"
            translation="[45,60]"
            width="400"
            height="100" />

        <LabelList
            id="playlistList"
            translation="[90, 180]"
            itemSize="[290, 60]"
            numRows="11"
            itemSpacing="[0, 10]"
            color="0x555555DD"/>
    </Rectangle>
    
    <LabelList
    	id="channelList"
    	translation="[520, 120]"
    	itemSize="[830, 50]"
    	numRows="16"
    	itemSpacing="[0, 5]"
        color="0xCCCCCCDD"
    	visible="true"/>
    
    <!-- Video preview in the menu -->
    <Video
        id="PreviewVideo"
        translation="[1380, 145]"
        width="444"
        height="250"
        visible="true"
        focusable="false"
        enableUI="false"/>
    <Rectangle
        id="VideoClipLeft"
        translation="[1380, 145]"
        width="60"
        height="250"
        color="0x024c48FF"
        visible="true">    
    </Rectangle>

    <Rectangle
        id="muteHintContainer"
        translation="[1430, 460]"
        width="400"
        height="50"
        color="0x222222DD"
        visible="true">    
        <Label
            id="muteHintLabel"
            translation="[5, 10]"
            text="Press RIGHT to unmute"
            font="font:SmallSystemFont"
            color="0x8fcdc1DD"
            width="390"
            horizAlign="center"/>
    </Rectangle>

    <!-- TV overlaying preview -->
        <Poster
            id="TV overlay"
            uri="pkg:/images/retro-set.png"
            translation="[1410, 120]"
            width="480"
            height="327"/>

    <!-- Video to full screen -->
    <Video
        id="Video"
        translation="[0, 0]"
        width="1920"
        height="1080"
        visible="false"
        focusable="false"/>
    
    <Rectangle
        id="channelInfoOverlay"
        translation="[60, 880]"
        width="700"
        height="140"
        color="0x000000CC"
        visible="false">
        
        <Label
            id="channelInfoLabel"
            translation="[20, 15]"
            text=""
            font="font:MediumBoldSystemFont"
            color="0xFFFFFFFF"
            width="660"
            height="110"
            wrap="true"
            maxLines="3"/>
    </Rectangle>
    
    <Rectangle
        id="channelOverlay"
        translation="[0, 0]"
        width="550"
        height="1080"
        color="0x024c48CC"
        visible="false">
        
        <LabelList
            id="channelOverlayList"
            translation="[50, 30]"
            itemSize="[460, 50]"
            numRows="18"
            itemSpacing="[0, 5]"/>
    </Rectangle>
    
    <Rectangle
        id="loadingSpinnerContainer"
        translation="[850, 560]"
        width="420"
        height="60"
        color="0x333333DD"
        visible="true"> 
        <Label
    	    id="loadingSpinnerMessage"
    	    translation="[0, 0]"
    	    text="Loading playlist..."
    	    horizAlign="center"
    	    vertAlign="center"
    	    width="420"
    	    height="60"
    	    color="0xDDDDDDFF"
    	    font="font:LargeBoldSystemFont"/>
    </Rectangle>
    
    <get_channel_list
    	id="get_channel_list"
    	control="STOP"/>
    	
    <save_feed_url
    	id="save_feed_url"
    	control="STOP"/>
    	
</children>
</component>
