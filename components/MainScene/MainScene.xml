<?xml version="1.0" encoding="UTF-8"?>

<component name="MainScene" extends="Scene" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://rokudev.roku.com/rokudev/schema/RokuSceneGraph.xsd" initialFocus="playlistList">
<script type="text/brightscript" uri="pkg:/components/MainScene/MainScene.brs"/>
<children>
    <Rectangle
        id="sidePanel"
        translation="[0, 0]"
        width="460"
        height="1080"
        color="0x8fcdc1DD"
        visible="true">
        
        <Poster
            id="logoImage"
            uri="pkg:/images/selectaview.png"
            translation="[45,60]"
            width="400"
            height="100" />

        <LabelList
            id="playlistList"
            translation="[90, 180]"
            itemSize="[290, 60]"
            numRows="11"
            itemSpacing="[0, 10]"
            color="0x555555DD"/>
    </Rectangle>
    
    <LabelList
    	id="channelList"
    	translation="[520, 120]"
    	itemSize="[830, 50]"
    	numRows="16"
    	itemSpacing="[0, 5]"
        color="0xCCCCCCDD"
        sectionDividerHeight="40"
        sectionDividerFont="font:SmallBoldSystemFont"
        sectionDividerTextColor="0x8fcdc0FF"
        sectionDividerTopPadding="10"
    	visible="true"/>
    
    <!-- Video preview in the menu -->
    <Video
        id="PreviewVideo"
        translation="[1380, 145]"
        width="444"
        height="250"
        visible="true"
        focusable="false"
        enableUI="false"/>
    <Rectangle
        id="VideoClipLeft"
        translation="[1380, 145]"
        width="60"
        height="250"
        color="0x024c48FF"
        visible="true">    
    </Rectangle>

    <Rectangle
        id="muteHintContainer"
        translation="[1430, 460]"
        width="400"
        height="50"
        color="0x222222DD"
        visible="true">    
        <Label
            id="previewHintLabel"
            translation="[5, 10]"
            text="Press RIGHT to mute"
            font="font:SmallSystemFont"
            color="0x8fcdc1DD"
            width="390"
            horizAlign="center"/>
    </Rectangle>

    <!-- TV overlaying preview -->
        <Poster
            id="TV overlay"
            uri="pkg:/images/retro-set.png"
            translation="[1410, 120]"
            width="480"
            height="327"/>

    <!-- Video to full screen -->
    <!-- Removed: PreviewVideo is now used for both preview and fullscreen -->

    <!-- Mute indicator overlay -->
    <Rectangle
        id="muteIndicatorContainer"
        translation="[1740, 40]"
        width="140"
        height="103"
        color="0x000000CC"
        visible="false">
        <Poster
            id="muteIndicatorImage"
            translation="[10, 10]"
            width="120"
            height="83"
            uri=""/>
    </Rectangle>
    
    <Rectangle
        id="channelInfoOverlay"
        translation="[60, 860]"
        width="700"
        height="170"
        color="0x000000CC"
        visible="false">
        
        <Label
            id="channelInfoLabel"
            translation="[20, 15]"
            text=""
            font="font:MediumBoldSystemFont"
            color="0xFFFFFFFF"
            width="660"
            height="90"
            wrap="true"
            maxLines="2"/>

        <Label
            id="clockLabel"
            translation="[20, 120]"
            text=""
            font="font:SmallSystemFont"
            color="0xAAAAAAFF"
            width="660"
            height="35"/>
    </Rectangle>

    <!-- Error overlay - centered on screen -->
    <Rectangle
        id="errorOverlay"
        translation="[460, 240]"
        width="1000"
        height="560"
        color="0x000000EE"
        visible="false">

        <Label
            id="errorTitleLabel"
            translation="[30, 30]"
            text=""
            font="font:LargeBoldSystemFont"
            color="0xFF4444FF"
            width="940"
            height="60"/>

        <Label
            id="errorChannelLabel"
            translation="[30, 100]"
            text=""
            font="font:MediumBoldSystemFont"
            color="0xFFFFFFFF"
            width="940"
            height="50"/>

        <Label
            id="errorMessageLabel"
            translation="[30, 160]"
            text=""
            font="font:SmallSystemFont"
            color="0xCCCCCCFF"
            width="940"
            height="320"
            wrap="true"
            maxLines="10"/>

        <Label
            translation="[30, 510]"
            text="Press OK to dismiss"
            font="font:SmallSystemFont"
            color="0x888888FF"
            width="940"
            height="35"/>
    </Rectangle>
    
    <!-- Buffer progress bar -->
    <Rectangle
        id="bufferContainer"
        translation="[1467, 252]"
        width="283"
        height="36"
        color="0x000000FF"
        visible="false">
        <!-- Track (unloaded) -->
        <Rectangle
            id="bufferTrack"
            translation="[3, 3]"
            width="277"
            height="30"
            color="0x024c48FF"/>
        <!-- Fill (loaded) -->
        <Rectangle
            id="bufferFill"
            translation="[3, 3]"
            width="0"
            height="30"
            color="0x8fcdc0FF"/>
        <!-- Percentage label -->
        <Label
            id="bufferLabel"
            translation="[0, 6]"
            text=""
            font="font:SmallSystemFont"
            color="0xFFFFFFFF"
            width="283"
            height="24"
            horizAlign="center"/>
    </Rectangle>

    <Rectangle
        id="channelOverlay"
        translation="[0, 0]"
        width="550"
        height="1080"
        color="0x024c48CC"
        visible="false">
        
        <LabelList
            id="channelOverlayList"
            translation="[50, 30]"
            itemSize="[460, 50]"
            numRows="18"
            itemSpacing="[0, 5]"/>
    </Rectangle>
    
    <Rectangle
        id="loadingSpinnerContainer"
        translation="[850, 560]"
        width="420"
        height="60"
        color="0x333333DD"
        visible="true"> 
        <Label
    	    id="loadingSpinnerMessage"
    	    translation="[0, 0]"
    	    text="Loading playlist..."
    	    horizAlign="center"
    	    vertAlign="center"
    	    width="420"
    	    height="60"
    	    color="0xDDDDDDFF"
    	    font="font:LargeBoldSystemFont"/>
    </Rectangle>
    
    <!-- Invisible focus trap used when error overlay is showing -->
    <Rectangle
        id="focusTrap"
        translation="[0, 0]"
        width="1"
        height="1"
        color="0x00000000"
        visible="false"
        focusable="true"/>

    <get_channel_list
    	id="get_channel_list"
    	control="STOP"/>
    	
</children>
</component>
